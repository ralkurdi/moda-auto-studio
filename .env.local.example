# ─────────────────────────────────────────────────────────────────────────────
# MODA Auto Studio — environment variables
#
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored — never commit real secrets. Public vars (NEXT_PUBLIC_*) are
# exposed to the browser; everything else is server-only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<PROJECT_REF>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Studio ──────────────────────────────────────────────────────────────────
OWNER_EMAIL=book@modaautostudio.com

# ── Stripe (Phase 2 — $300 refundable deposit on jobs ≥ $1,000) ─────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLIC_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Twilio (Phase 2 — SMS confirmations) ────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Gmail SMTP (Phase 2 — transactional email via book@modaautostudio.com) ──
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (requires 2FA on the Google account first)
# GMAIL_USER=book@modaautostudio.com
# GMAIL_APP_PASSWORD=

# ── Cal.com (Phase 2 — booking calendar embed) ──────────────────────────────
# No keys needed for the public embed widget. Add CAL_USERNAME if using API.
# CAL_USERNAME=modaautostudio

# ── Google Places (Phase 4 — daily reviews sync) ────────────────────────────
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACE_ID=

# ── Instagram Basic Display (Phase 4 — @modaautostudio gallery feed) ────────
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
